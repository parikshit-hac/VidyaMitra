# Backend Environment Variables
# Copy this file to .env and fill in your actual credentials

# OpenAI API Key (for resume analysis and training) OR any model api key
OPENAI_API_KEY=sk-proj-your-key-here

# Google API Key (for Google services)
GOOGLE_API_KEY=your-google-api-key

# YouTube API Key (for video recommendations)
YOUTUBE_API_KEY=your-youtube-api-key

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Pexels API Key (for images)
PEXELS_API_KEY=your-pexels-key

# News API Key (for news and job updates)
NEWS_API_KEY=your-news-api-key

# Exchange API Key (for currency/market data)
EXCHANGE_API_KEY=your-exchange-api-key

# JWT Secret (for authentication)
JWT_SECRET=change-this-to-a-strong-secret-key
